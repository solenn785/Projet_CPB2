import os
import random
import numpy as np
from PIL import Image
import pandas as pd
from sklearn.linear_model import LogisticRegression
from sklearn.model_selection import cross_val_predict, StratifiedKFold
from sklearn.metrics import accuracy_score, confusion_matrix # Ajout de confusion_matrix
